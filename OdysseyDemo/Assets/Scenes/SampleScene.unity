  m_Script: {fileID: 11500000, guid: 19028e5bab29970489bed993b2bf4f96, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CirceDialogue
  uiPanel: {fileID: 1679247766}
  dialogueText: {fileID: 1320512251}
  answersPanel: {fileID: 95934495}
  answerOneText: {fileID: 952184775}
  answerTwoText: {fileID: 832871666}
  answerOne: Kind Circe, i must return to my wife and son!
  answerTwo: Paradise? This is worse than hell you horrid hag.
  firstLine: Sweet Odysseus, do you truly want to leave? Forget Ithaca, let it become
    a mere fond memory.
  questionText: Why don't you stay with me in this paradise?
  responseToAnswerOne: Noble as always. I respect your honesty and your commitment
    to your family. May you have a safe passage back home, noble Odysseus.
  responseToAnswerTwo: Do you forget you adress the great Circe? You shall pay for
    you hubris you insolent mortal!
  selectedPrefix: '>'
  normalPrefix: 
  livesManager: {fileID: 784517035}
  livesGainedFromAnswerOne: 1
  livesLostFromAnswerTwo: 1
